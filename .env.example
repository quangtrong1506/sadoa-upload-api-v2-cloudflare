# Environment variables (Cloudflare Workers)
#
# Locally these are provided via `wrangler.jsonc` -> "vars".
# For secrets use `wrangler secret put <NAME>` (never commit real secrets).
# This file is a documentation template; copy to `.env` / `.dev.vars` if needed
# by your local tooling. The app reads config from the Cloudflare `env` binding,
# NOT from process.env directly.

NODE_ENV=development
APP_NAME=sadoa-upload-api-v2-cloudflare
LOG_LEVEL=info

# API mount prefix (routes are served under this path, e.g. /api/health)
API_PREFIX=/api

# CORS allow-list. Use "*" for permissive, or a comma-separated list of origins.
CORS_ORIGIN=*

# In-memory fixed-window rate limiter (per isolate).
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# API key required by POST /api/images/upload (send via x-api-key header).
API_KEY=dev_api_key

# Telegram bot used as the image store (POST /api/images/upload, GET /images/:id).
# Set these via `wrangler secret put` for real deployments.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
