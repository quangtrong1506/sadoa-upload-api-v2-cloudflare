{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "get-image-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "NODE_ENV": "development",
    "APP_NAME": "get-image-api",
    "LOG_LEVEL": "info",
    "API_PREFIX": "/api",
    "CORS_ORIGIN": "*",
    "RATE_LIMIT_MAX": "100",
    "RATE_LIMIT_WINDOW_MS": "60000",
    "X_API_KEY": "",
    "TELEGRAM_BOT_TOKEN": "",
    "TELEGRAM_CHAT_ID": ""
  },
  "placement": {
    "mode": "smart"
  }
}
